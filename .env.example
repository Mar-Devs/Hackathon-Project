# ── AI layer (optional but recommended) ────────────────────────────────
# Used only by the serverless function in /api. Never exposed to the client.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CARB_MODEL=claude-sonnet-4-6

# ── Supabase (optional) ────────────────────────────────────────────────
# If omitted, CARB falls back to in-browser localStorage for save/resume
# and longitudinal tracking — the app is fully functional without these.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
